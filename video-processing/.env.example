# Required
GROQ_API_KEY=your_groq_api_key_here

# Optional — Whisper model size (small | medium | large-v3)
# small  = ~500 MB VRAM, fast
# medium = ~1.5 GB VRAM, more accurate
# large-v3 = ~3.5 GB VRAM, best (fits in RTX 3050 4GB if nothing else runs)
WHISPER_MODEL=small

# Optional — compute device (auto | cuda | cpu)
# auto = uses CUDA if available, else CPU
WHISPER_DEVICE=auto

# Optional — compute type (float16 | int8)
# float16 on GPU, int8 on CPU (set automatically when device=cpu)
WHISPER_COMPUTE=float16

# Port this service listens on
PORT=8001
